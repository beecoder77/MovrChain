# Copy to .env and fill in (never commit .env)
# Must start with 0x (deploy.sh will add it if missing)
PRIVATE_KEY=0xyour_deployer_private_key_here
# Optional second wallet with ADMIN rights
ADMIN_ADDRESS=

# After deploy — used by check-role.sh / CheckRole.s.sol / art scripts
MOVR_TOKEN=
ATTESTATION=
ACHIEVEMENT_NFT=
STAKING=
MOVR_STAKING=
# Address to inspect (optional; defaults to wallet from PRIVATE_KEY)
CHECK_ADDRESS=

# After ./deploy-profile.sh
MOVR_PROFILE=

# Clubs / challenges / feed / rewards
CLUB_REGISTRY=
CLUB_MEMBER_NFT=
CLUB_BADGE_NFT=
CLUB_CHALLENGES=
MOVR_FEED=
MILESTONE_REWARD=

# Upgrade governance (filled by ./redeploy-all.sh → DeployUpgradeableStack)
# Required BEFORE cutover:
MULTISIG_SIGNER_2=
MULTISIG_SIGNER_3=
# 1 = creator-only (hackathon default); 2 = production 2-of-3
MULTISIG_THRESHOLD=1
# Written AFTER cutover:
MOVR_MULTISIG=
TIMELOCK=
TREASURY_BEACON=
TREASURY_IMPL=
# Optional:
# TIMELOCK_DELAY=86400

# Art: npm run generate:art → contracts/metadata/*.uri.txt
# First NFT deploy lacked setAchievementURI — use ./redeploy-nft-staking.sh once,
# then ./fund-rewards.sh, then ./update-achievement-uris.sh for future art refreshes.
